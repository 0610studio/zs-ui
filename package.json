{
  "name": "@0610studio/zs-ui",
  "version": "0.17.0",
  "private": false,
  "description": "EXPO ZS-UI",
  "type": "commonjs",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "android",
    "ios",
    "app.plugin.js",
    "expo-module.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start:android": "cd example && yarn install && npx expo run:android",
    "start:ios": "cd example && yarn install && npx expo run:ios --device",
    "build": "expo-module build",
    "prepare": "expo-module prepare",
    "---------------------------------------------------------------------------": "",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "CI=true expo-module test --watchAll=false --passWithNoTests ",
    "test:all": "expo-module test --clearCache && (CI=true expo-module test --watchAll=false --passWithNoTests --coverage --coverageReporters=json-summary --json --outputFile=test-results.json || true) && node scripts/update-test-results.js",
    "test:cov": "CI=true expo-module test --coverage",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "zs-ui",
    "ZsUi"
  ],
  "repository": "https://github.com/0610studio/zs-ui",
  "author": "righthot <0610studio@naver.com> ()",
  "license": "MIT",
  "homepage": "https://github.com/0610studio/zs-ui",
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/metro-runtime": "6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.17",
    "babel-jest": "^29",
    "eslint": "^8.57.1",
    "expo": "54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-module-scripts": "^5.0.8",
    "expo-modules-core": "3.0.29",
    "expo-navigation-bar": "~5.0.10",
    "expo-router": "~6.0.23",
    "jest": "^29",
    "jest-expo": "~54.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "4.1.6",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "expo": ">=54.0.0",
    "expo-navigation-bar": ">=5.0.0",
    "expo-router": "*",
    "react": "*",
    "react-native": ">=0.81.0",
    "react-native-reanimated": ">=4.1.0 <5.0.0",
    "react-native-safe-area-context": "*",
    "react-native-svg": "*",
    "react-native-worklets": ">=0.5.0 <0.9.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": false
    },
    "expo-navigation-bar": {
      "optional": false
    },
    "expo": {
      "optional": false
    },
    "react": {
      "optional": false
    },
    "react-native": {
      "optional": false
    },
    "react-native-reanimated": {
      "optional": false
    },
    "react-native-worklets": {
      "optional": false
    },
